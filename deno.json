    "./css/mist.css": "./css/mist.css",
    "./css/monokai-cyan.css": "./css/monokai-cyan.css",
    "./css/monokai-green.css": "./css/monokai-green.css",
    "./css/monokai-pink.css": "./css/monokai-pink.css",
    "./css/olive-amber-safari.css": "./css/olive-amber-safari.css",
    "./css/olive.css": "./css/olive.css",
