    "./css/pink-emerald.css": "./css/pink-emerald.css",
    "./css/pink-teal.css": "./css/pink-teal.css",
    "./css/purple-yellow.css": "./css/purple-yellow.css",
    "./css/rainbow.css": "./css/rainbow.css",
