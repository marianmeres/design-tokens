{
  "name": "@marianmeres/design-tokens",
  "version": "1.4.1",
  "exports": {
    ".": "./src/mod.ts",
    "./reboot": "./src/reboot-bridge.ts",
    "./themes": "./src/themes/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-read",
    "test:watch": "deno test --allow-read --watch",
    "npm:build": "deno run -A scripts/build-npm.ts",
    "npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish && deno task npm:publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish",
    "themes:build": "deno run -A scripts/build-themes-mod.ts",
    "css:build": "deno run -A scripts/build-css.ts",
    "preview:build": "deno run -A jsr:@marianmeres/deno-build --root theme-preview-builder/src --outdir theme-preview-builder/dist ",
    "preview:dev": "deno run -A jsr:@marianmeres/deno-build --root theme-preview-builder/src --outdir theme-preview-builder/dist --watch"
  },
  "imports": {
    "@marianmeres/npmbuild": "jsr:@marianmeres/npmbuild@^1.14.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4,
    "proseWrap": "preserve"
  }
}
